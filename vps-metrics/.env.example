# === API ===
API_SECRET=change-me-to-a-secure-random-string

# === Domain (for SSL certificate) ===
# Leave empty to skip SSL setup
DOMAIN=

# === Performance ===
# Uvicorn workers (API concurrency)
WORKERS=4
# Celery workers (parallel audio processing jobs)
CELERY_CONCURRENCY=2

# === GPU (optional) ===
# Set to "true" to enable CUDA support
USE_GPU=false
