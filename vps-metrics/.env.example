# === API ===
API_SECRET=change-me-to-a-secure-random-string

# === Domain (for SSL certificate — leave empty for local) ===
DOMAIN=

# === Performance ===
# Uvicorn workers (API concurrency) — with GPU, keep 1-2 to avoid VRAM conflicts
WORKERS=2
# Celery workers (parallel audio processing jobs) — 1 is safest with GPU
CELERY_CONCURRENCY=1

# === Network ===
# Set to your machine's local IP if you want LAN access (e.g., 192.168.1.100)
# Leave empty for localhost-only
HOST_IP=
